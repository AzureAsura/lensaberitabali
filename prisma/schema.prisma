generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  role          String    @default("user")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Berita {
  id              String   @id @default(cuid())
  judul           String
  penulis         String
  gambar          String
  deskripsiGambar String?
  konten          String   @db.Text
  kategori        String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("berita")
}

model TentangKami {
  id          String   @id @default(cuid())
  tentangKami String   @db.Text @map("tentang_kami")
  visiMisi    String   @db.Text @map("visi_misi")
  layanan     String   @db.Text
  email       String
  whatsapp    String
  instagram   String
  tiktok      String
  youtube     String
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tentang_kami")
}

model Iklan {
  id        String   @id @default(cuid())
  gambar    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("iklan")
}

model Kategori {
  id        String   @id @default(cuid())
  nama      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kategoris")
}
