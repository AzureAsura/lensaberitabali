{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true
  },
  "files.exclude": {
    "**/.next": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true
  },
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "editor.suggestDelay": 0,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "off"
  }
}
